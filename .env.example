# Para Vercel u otro host: creá una base PostgreSQL (Neon, Supabase, Vercel Postgres)
# y pegá la URL aquí y en las variables de entorno del proyecto.

# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
